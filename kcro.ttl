kcro:Pod rdf:type owl:Class ;
         rdfs:subClassOf kcro:WorkloadResource .


###  https://w3id.org/kcro#PodRunAsRoot
kcro:PodRunAsRoot rdf:type owl:Class ;
                  rdfs:subClassOf kcro:VulnerabilityByCommission ,
                [ rdf:type owl:Restriction ;
                  owl:onProperty gufo:inheresIn ;
                  owl:someValuesFrom kcro:Pod
                ] ;
                  dcterms:source kcro:Rahman2024 ;
                  rdfs:label "Pod Runs As Root"@en ;
                  kcro:corpusCount 234 ;
                  kcro:datasetKey "pod.securityContext.runAsUser=0" ;
                  kcro:groundingNote "Pod-level counterpart of the above; same securityContext family." .


###  https://w3id.org/kcro#PrivilegeEscalationAllowed
kcro:PrivilegeEscalationAllowed rdf:type owl:Class ;
                                rdfs:subClassOf kcro:VulnerabilityByCommission ,
                [ rdf:type owl:Restriction ;
                  owl:onProperty gufo:inheresIn ;
                  owl:someValuesFrom kcro:Container
                ] ;
                                dcterms:source kcro:Rahman2024 ;
                                rdfs:label "Privilege Escalation Allowed"@en ;
                                kcro:corpusCount 103 ;
                                kcro:datasetKey "container.securityContext.allowPrivilegeEscalation=true" ;
                                kcro:groundingNote "Explicit in Rahman 2024 ('Escalated Privileges for Child Container Processes')." .


###  https://w3id.org/kcro#PrivilegedContainer
kcro:PrivilegedContainer rdf:type owl:Class ;
                         rdfs:subClassOf kcro:VulnerabilityByCommission ,
                [ rdf:type owl:Restriction ;
                  owl:onProperty gufo:inheresIn ;
                  owl:someValuesFrom kcro:Container
                ] ;
                         dcterms:source kcro:Aliforenko2025 ,
                                        kcro:Rahman2024 ;
                         rdfs:comment "Disinhibits container isolation; grounds a host-takeover capacity inhering in the Container."@en ;
                         rdfs:label "Privileged Container"@en ;
                         kcro:corpusCount 466 ;
                         kcro:datasetKey "container.securityContext.privileged=true" ;
                         kcro:groundingNote "Explicit in Rahman 2024 (category 'Privileged securityContext') and Aliforenko 2025 (sec. 5.4)." .


