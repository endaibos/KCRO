kcro:ImageTagLatest rdf:type owl:Class ;
                    rdfs:subClassOf kcro:ImageTagPolicy ;
                    rdfs:label "Image Tag = latest"@en ;
                    skos:note "Modeled as a quality phase, not a Vulnerability: like ServiceExposureLevel, it is risk-contributing (provenance/reproducibility) rather than directly exploitable." ;
                    kcro:corpusCount 1974 ;
                    kcro:datasetKey "container.image.tag=latest" .


