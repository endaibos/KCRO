###  gUFO meta-typing for the misconfiguration taxonomy (added in 0.3.0).
###  Leaf vulnerability classes are gufo:Kind: rigid, intrinsically grounded,
###  and supplying the identity principle gUFO requires every endurant to have.
###  Value-based subclasses of the two quality kinds are gufo:Phase: the same
###  quality individual can move between values when the manifest changes.

kcro:VulnerabilityByCommission rdf:type owl:NamedIndividual ,
                                        gufo:Category .


kcro:VulnerabilityByOmission rdf:type owl:NamedIndividual ,
                                      gufo:Category .


kcro:AbsentIngressTLS rdf:type owl:NamedIndividual ,
                               gufo:Kind .


kcro:AbsentResourceLimit rdf:type owl:NamedIndividual ,
                                  gufo:Kind .


kcro:AbsentRunAsNonRoot rdf:type owl:NamedIndividual ,
                                 gufo:Kind .


kcro:AddedLinuxCapabilities rdf:type owl:NamedIndividual ,
                                     gufo:Kind .


kcro:AutomountTokenEnabled rdf:type owl:NamedIndividual ,
                                    gufo:Kind .


kcro:ClusterAdminBinding rdf:type owl:NamedIndividual ,
                                  gufo:Kind .


kcro:ContainerRunAsRoot rdf:type owl:NamedIndividual ,
                                 gufo:Kind .


kcro:DefaultServiceAccount rdf:type owl:NamedIndividual ,
                                    gufo:Kind .


kcro:HostIPCPod rdf:type owl:NamedIndividual ,
                         gufo:Kind .


kcro:HostNetworkPod rdf:type owl:NamedIndividual ,
                             gufo:Kind .


kcro:HostPIDPod rdf:type owl:NamedIndividual ,
                         gufo:Kind .


kcro:PodRunAsRoot rdf:type owl:NamedIndividual ,
                           gufo:Kind .


kcro:PrivilegeEscalationAllowed rdf:type owl:NamedIndividual ,
                                         gufo:Kind .


kcro:PrivilegedContainer rdf:type owl:NamedIndividual ,
                                  gufo:Kind .


kcro:RunAsNonRootDisabled rdf:type owl:NamedIndividual ,
                                   gufo:Kind .


kcro:WildcardAPIGroups rdf:type owl:NamedIndividual ,
                                gufo:Kind .


kcro:WildcardResources rdf:type owl:NamedIndividual ,
                                gufo:Kind .


kcro:WildcardVerbs rdf:type owl:NamedIndividual ,
                            gufo:Kind .


kcro:ClusterIPExposure rdf:type owl:NamedIndividual ,
                                gufo:Phase .


kcro:ExternalNameExposure rdf:type owl:NamedIndividual ,
                                   gufo:Phase .


kcro:ImageTagLatest rdf:type owl:NamedIndividual ,
                             gufo:Phase .


kcro:ImageTagMissing rdf:type owl:NamedIndividual ,
                              gufo:Phase .


kcro:LoadBalancerExposure rdf:type owl:NamedIndividual ,
                                   gufo:Phase .


kcro:NodePortExposure rdf:type owl:NamedIndividual ,
                               gufo:Phase .


###  https://w3id.org/kcro#exampleAdminVuln
kcro:exampleAdminVuln rdf:type owl:NamedIndividual ,
                               kcro:ClusterAdminBinding ;
                      gufo:inheresIn kcro:exampleBinding ;
                      rdfs:label "cluster-admin grant vulnerability on the binding"@en .


###  https://w3id.org/kcro#exampleAttacker
kcro:exampleAttacker rdf:type owl:NamedIndividual ,
                              kcro:Pod ,
                              kcro:ThreatAgent ;
                     rdfs:label "compromised workload"@en .


###  https://w3id.org/kcro#exampleBinding
kcro:exampleBinding rdf:type owl:NamedIndividual ,
                             kcro:ClusterRoleBinding ;
                    gufo:mediates kcro:exampleClusterAdminRole ,
                                  kcro:exampleSA ;
                    rdfs:label "binds default SA to cluster-admin"@en .


###  https://w3id.org/kcro#exampleCapability
kcro:exampleCapability rdf:type owl:NamedIndividual ,
                                kcro:ThreatCapability ;
                       gufo:inheresIn kcro:exampleAttacker ;
                       kcro:exploits kcro:exampleAdminVuln ,
                                     kcro:examplePrivileged ;
                       rdfs:label "container-breakout + privilege-escalation capability"@en .


###  https://w3id.org/kcro#exampleClusterAdminRole
kcro:exampleClusterAdminRole rdf:type owl:NamedIndividual ,
                                      kcro:ClusterRole ;
                             rdfs:label "cluster-admin ClusterRole"@en .


###  https://w3id.org/kcro#exampleContainer
kcro:exampleContainer rdf:type owl:NamedIndividual ,
                               kcro:Container ;
                      gufo:isProperPartOf kcro:examplePod ;
                      rdfs:label "example app container"@en .


###  https://w3id.org/kcro#exampleIdentity
kcro:exampleIdentity rdf:type owl:NamedIndividual ,
                              kcro:IdentityAssignment ;
                     gufo:mediates kcro:examplePod ,
                                   kcro:exampleSA ;
                     rdfs:label "pod -> serviceAccount assignment"@en .


###  https://w3id.org/kcro#examplePod
kcro:examplePod rdf:type owl:NamedIndividual ,
                         kcro:Pod ;
                rdfs:label "example workload pod"@en .


###  https://w3id.org/kcro#examplePrivileged
kcro:examplePrivileged rdf:type owl:NamedIndividual ,
                                kcro:PrivilegedContainer ;
                       gufo:inheresIn kcro:exampleContainer ;
                       rdfs:label "privileged=true on example container"@en .


###  https://w3id.org/kcro#exampleRisk
kcro:exampleRisk rdf:type owl:NamedIndividual ,
                          kcro:Risk ;
                 gufo:mediates kcro:exampleAttacker ,
                               kcro:examplePod ;
                 rdfs:label "host-takeover risk"@en .


###  https://w3id.org/kcro#exampleSA
kcro:exampleSA rdf:type owl:NamedIndividual ,
                        kcro:ServiceAccount ;
               rdfs:label "default ServiceAccount"@en .


#################################################################
#    Annotations
#################################################################

kcro:ClusterRole rdfs:label "ClusterRole"@en .


kcro:ClusterRoleBinding rdfs:comment "Cluster-scoped binding relator mediating subjects and a ClusterRole."@en ;
                        rdfs:label "ClusterRoleBinding"@en ;
                        skos:scopeNote "Aggregates ClusterRoleBinding->ClusterRole (roleRef), ClusterRoleBinding->ServiceAccount (subjects)." .


kcro:ConfigMap rdfs:label "ConfigMap"@en .


kcro:Container rdfs:comment "Bearer of container-level security aspects. Distinct bearer from its Pod: pod-level and container-level settings inhere in different individuals."@en ;
               rdfs:label "Container"@en .


kcro:ContainerImage rdfs:comment "The software artifact a container runs. The bridge to the supply-chain / vulnerability world."@en ;
                    rdfs:label "Container Image"@en .


kcro:CronJob rdfs:label "CronJob"@en .


kcro:DaemonSet rdfs:label "DaemonSet"@en .


kcro:DataResource rdfs:label "Data Resource"@en .


kcro:Deployment rdfs:label "Deployment"@en .


kcro:EnvReference rdfs:label "Environment Reference"@en ;
                  skos:scopeNote "Pod -> ConfigMap/Secret (envFrom)." .


kcro:IdentityAssignment rdfs:label "Identity Assignment"@en ;
                        skos:scopeNote "Pod -> ServiceAccount (serviceAccountName). Security-critical: ties a workload to its cluster identity." .


kcro:IdentityResource rdfs:comment "Subjects of access control."@en ;
                      rdfs:label "Identity Resource"@en .


kcro:ImageReference rdfs:label "Image Reference"@en ;
                    skos:scopeNote "Pod/Container -> ContainerImage (image). Bridge to the supply-chain layer." .


kcro:ImageTagPolicy rdfs:comment "Quality of a Container's image reference taking a value in {digest-pinned, explicit-tag, latest, absent}. 'latest' and 'absent' undermine reproducibility and provenance."@en ;
                    rdfs:label "Image Tag Policy"@en ;
                    kcro:groundingNote "Image immutability best practice (pin by digest). NOT enumerated in Rahman 2024's 11 categories; grounded in the Kubernetes Configuration Best Practices documentation and general CIS guidance. Verified 2026-06-10 against KGSecConfig (Haque 2022): the paper mines component-level secured-configuration knowledge from official documentation and does not enumerate this manifest-level pattern, so it is not cited." .


kcro:InformationObject rdfs:comment "A descriptor: a piece of information that represents a world entity (e.g. a STIX Vulnerability SDO, a CVE record, a CWE entry). Distinct from the world entity it describes."@en ;
                       rdfs:label "Information Object"@en .


kcro:Ingress rdfs:label "Ingress"@en .


kcro:IngressBackend rdfs:label "Ingress Backend"@en ;
                    skos:scopeNote "Ingress -> Service (backend)." .


kcro:Job rdfs:label "Job"@en .


kcro:KubernetesObject rdfs:comment "Top non-sortal category generalising every Kubernetes resource kind catalogued in the corpus (541 distinct kinds). A Category because it is rigid but spans many kinds with different identity principles."@en ;
                      rdfs:label "Kubernetes Object"@en .


kcro:KubernetesRelation rdfs:comment "Top category of relators reifying the 18 inter-resource relationship types catalogued in the corpus."@en ;
                        rdfs:label "Kubernetes Relation"@en .


kcro:LossEvent rdfs:comment "An impact on a security goal (confidentiality/integrity/availability) caused by a threat event."@en ;
               rdfs:label "Loss Event"@en .


kcro:NetworkPolicy rdfs:comment "Its ABSENCE (a flat allow-all network) is the security-relevant condition (Aliforenko 2025)."@en ;
                   rdfs:label "NetworkPolicy"@en .


kcro:NetworkPolicyScope rdfs:label "Network Policy Scope"@en ;
                        skos:scopeNote "NetworkPolicy -> Pod (podSelector). Its absence leaves an allow-all network (Aliforenko 2025)." .


kcro:NetworkResource rdfs:label "Network Resource"@en .


kcro:PermissionResource rdfs:comment "RBAC rules and their bindings."@en ;
                        rdfs:label "Permission Resource"@en .


kcro:Pod rdfs:comment "Smallest deployable unit; the principal bearer of pod-level security aspects."@en ;
         rdfs:label "Pod"@en .


kcro:ReplicaSet rdfs:label "ReplicaSet"@en .


kcro:Risk rdfs:comment "A relator mediating an asset-at-risk (a Kubernetes object bearing a vulnerability) and a threat agent (bearing a capability that can exploit it)."@en ;
          rdfs:label "Risk"@en .


kcro:Role rdfs:label "Role"@en .


kcro:RoleBinding rdfs:comment "A namespaced relator mediating one or more subjects (e.g. ServiceAccount) and a Role/ClusterRole. Instances bear their own properties (roleRef, subjects) and can themselves be the bearer of a ClusterAdminBinding vulnerability."@en ;
                 rdfs:label "RoleBinding"@en ;
                 skos:scopeNote "Aggregates corpus relationships RoleBinding->ServiceAccount (subjects), RoleBinding->Role (roleRef), RoleBinding->ClusterRole (roleRef)." .


kcro:Secret rdfs:label "Secret"@en .


kcro:SecurityDisposition rdfs:comment "A dispositional security-relevant aspect: a capacity that may be manifested in a (loss) event. Inheres in exactly one bearer."@en ;
                         rdfs:label "Security Disposition"@en .


kcro:SecurityQuality rdfs:comment "A value-bearing security-relevant aspect (it has a quality value), inhering in a Kubernetes object."@en ;
                     rdfs:label "Security Quality"@en .


kcro:Service rdfs:label "Service"@en .


kcro:ServiceAccount rdfs:label "ServiceAccount"@en .


kcro:ServiceExposureLevel dcterms:source kcro:Aliforenko2025 ;
                          rdfs:comment "Quality of a Service taking one value from {ClusterIP, NodePort, LoadBalancer, ExternalName}. ClusterIP is the non-exposed default; the others raise the exposure surface and are risk-contributing rather than vulnerabilities in themselves."@en ;
                          rdfs:label "Service Exposure Level"@en ;
                          kcro:groundingNote "External-exposure analysis in Aliforenko 2025 (sec. 5.4): LoadBalancer/NodePort/Ingress flagged as internet-exposed." .


kcro:ServiceRouting rdfs:label "Service Routing"@en ;
                    skos:scopeNote "Service -> Pod (selector)." .


kcro:StatefulSet rdfs:label "StatefulSet"@en .


kcro:ThreatAgent rdfs:comment "An entity (e.g. a compromised container, an external attacker) bearing a threat capability. RoleMixin: 'threat agent' is a relational role played by objects of various kinds."@en ;
                 rdfs:label "Threat Agent"@en .


kcro:ThreatCapability rdfs:comment "A disposition inhering in a threat agent whose manifestation exploits a vulnerability."@en ;
                      rdfs:label "Threat Capability"@en .


kcro:ThreatEvent rdfs:comment "The manifestation event in which a threat capability acts on a vulnerability."@en ;
                 rdfs:label "Threat Event"@en .


kcro:ThreatIntelDescriptor rdfs:label "Threat-Intelligence Descriptor"@en ;
                           skos:editorialNote "TODO: align to STIX 2.1 SDOs (Vulnerability, Attack-Pattern, Course-of-Action) and UCO observable objects via owl:equivalentClass once the import strategy is fixed. STIX/UCO are not native OWL, so alignment is by annotation here."@en .


kcro:VolumeMount rdfs:label "Volume Mount"@en ;
                 skos:scopeNote "Pod -> Secret/ConfigMap/PersistentVolumeClaim (volume)." .


kcro:Vulnerability rdfs:comment "A rigid category of dispositions whose grounding (a dangerous value or a missing protective setting) makes their bearer exploitable. A gufo:Category because vulnerabilities range over disposition kinds with different bearers (Pod, Container, RBAC binding...). Typed Category rather than RoleMixin since the leaf vulnerability kinds are rigid (decidable from the manifest alone) and a rigid type may not specialize an anti-rigid one; exploitability-in-context is captured by the Risk relator instead. Follows the COVER treatment of vulnerability-as-disposition."@en ;
                   rdfs:label "Vulnerability"@en .


kcro:WorkloadManagement rdfs:label "Workload Management"@en ;
                        skos:scopeNote "Deployment/StatefulSet/DaemonSet -> Pod (template+selector)." .


kcro:WorkloadResource rdfs:comment "Bearers of runtime security configuration."@en ;
                      rdfs:label "Workload Resource"@en .


#################################################################
#    General axioms
#################################################################

[ rdf:type owl:AllDisjointClasses ;
  owl:members ( kcro:DataResource
                kcro:IdentityResource
                kcro:NetworkResource
                kcro:PermissionResource
                kcro:WorkloadResource
              )
] .


