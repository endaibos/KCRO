@prefix : <https://w3id.org/kcro#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix gufo: <http://purl.org/nemo/gufo#> .
@prefix kcro: <https://w3id.org/kcro#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@base <https://w3id.org/kcro#> .

<https://w3id.org/kcro> rdf:type owl:Ontology ;
                         owl:imports <http://purl.org/nemo/gufo> ;
                         dcterms:creator <https://orcid.org/0009-0000-0969-772X> ;
                         dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
                         dcterms:title "KCRO: Kubernetes Cybersecurity Research Ontology"@en ;
                         rdfs:comment """A security-focused domain ontology for Kubernetes, grounded in the
gUFO lightweight implementation of the Unified Foundational Ontology. The three
structural metrics extracted from the KubeObjects corpus map onto the three gUFO
endurant categories: resource kinds -> substantials (gufo:Object), security fields
-> intrinsic aspects (gufo:Quality / gufo:IntrinsicMode), inter-resource relationships
-> relators (gufo:Relator). The risk layer follows the COVER pattern of treating a
vulnerability as a special disposition."""@en ;
                         skos:editorialNote """AI-use disclosure: the ontology's scope, design decisions, and
literature grounding are the author's. Claude (Anthropic) was used as an assistant for ontology review
and refactoring (the v0.3.0 meta-typing and existential bearer restrictions), for formalising and
executing the competency-question SPARQL queries, and for documentation. All AI-assisted changes were reviewed by the author; OWL 2 DL consistency was verified by the author with HermiT in Protege."""@en ;
                         owl:versionIRI <https://w3id.org/kcro/0.3.0> ;
                         owl:versionInfo "0.3.0-draft" ;
                         dcterms:issued "2026-06-10"^^xsd:date ;
                         dcterms:modified "2026-06-15"^^xsd:date ;
                         dcterms:description "An OWL 2 DL ontology of Kubernetes security misconfigurations, grounded in gUFO and the KubeObjects corpus of 75,390 real-world manifests. KCRO models 17 in-scope resource kinds, 24 empirically grounded security-field patterns (split into omission and commission vulnerabilities), and 18 inter-resource relationship types reified as relators, with a COVER-style risk layer."@en ;
                         dcterms:publisher "University of Twente"@en ;
                         vann:preferredNamespacePrefix "kcro" ;
                         vann:preferredNamespaceUri "https://w3id.org/kcro#" ;
                         rdfs:seeAlso <https://github.com/endaibos/KCRO> .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/creator
dcterms:creator rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/source
dcterms:source rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
dcterms:title rdf:type owl:AnnotationProperty .



###  http://purl.org/vocab/vann/preferredNamespacePrefix
vann:preferredNamespacePrefix rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespaceUri
vann:preferredNamespaceUri rdf:type owl:AnnotationProperty .

###  http://www.w3.org/2004/02/skos/core#editorialNote
skos:editorialNote rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#note
skos:note rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#scopeNote
skos:scopeNote rdf:type owl:AnnotationProperty .


###  https://w3id.org/kcro#corpusCount
kcro:corpusCount rdf:type owl:AnnotationProperty ;
                 rdfs:comment "Number of objects/manifests exhibiting this finding in the KubeObjects corpus (75,390 deduplicated objects)."@en ;
                 rdfs:label "corpus count"@en .


###  https://w3id.org/kcro#datasetKey
kcro:datasetKey rdf:type owl:AnnotationProperty ;
                rdfs:comment "The exact field label produced by survey.py --security in security_analysis.json."@en ;
                rdfs:label "dataset key"@en .


###  https://w3id.org/kcro#groundingNote
kcro:groundingNote rdf:type owl:AnnotationProperty ;
                   rdfs:comment "Honest record of which cited source supports this field. Where a field is NOT explicitly enumerated in a source, this is stated so the claim is not overstated."@en ;
                   rdfs:label "grounding note"@en .


#################################################################
#    Object Properties
#################################################################

###  https://w3id.org/kcro#causesLoss
kcro:causesLoss rdf:type owl:ObjectProperty ;
                rdfs:domain kcro:ThreatEvent ;
                rdfs:range kcro:LossEvent ;
                rdfs:label "causes loss"@en .


###  https://w3id.org/kcro#describedBy
kcro:describedBy rdf:type owl:ObjectProperty ;
                 rdfs:range kcro:InformationObject ;
                 rdfs:comment "Links a world entity (e.g. a Vulnerability) to a descriptor (e.g. a STIX/CVE/CWE record). Keeps the descriptor distinct from the truthmaker."@en ;
                 rdfs:label "described by"@en .


###  https://w3id.org/kcro#exploits
kcro:exploits rdf:type owl:ObjectProperty ;
              rdfs:domain kcro:ThreatCapability ;
              rdfs:range kcro:Vulnerability ;
              rdfs:comment "A threat capability is able to take advantage of a vulnerability."@en ;
              rdfs:label "exploits"@en .


###  https://w3id.org/kcro#hasSecurityAspect
kcro:hasSecurityAspect rdf:type owl:ObjectProperty ;
                       owl:inverseOf gufo:inheresIn ;
                       rdfs:domain gufo:Endurant ;
                       rdfs:range gufo:Aspect ;
                       rdfs:comment "Named inverse of gufo:inheresIn, from a bearer to the qualities/dispositions inhering in it. Declared explicitly to avoid an anonymous inverse expression."@en ;
                       rdfs:label "has security aspect"@en .


###  https://w3id.org/kcro#manifestedThrough
kcro:manifestedThrough rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf gufo:manifestedIn ;
                       rdfs:domain kcro:Vulnerability ;
                       rdfs:range kcro:ThreatEvent ;
                       rdfs:comment "Links a vulnerability disposition to the event in which it is manifested."@en ;
                       rdfs:label "manifested through"@en .


#################################################################
#    Data properties
#################################################################

###  https://w3id.org/kcro#cweId
kcro:cweId rdf:type owl:DatatypeProperty ;
           rdfs:domain kcro:Vulnerability ;
           rdfs:range xsd:string ;
           rdfs:label "CWE id"@en ;
           skos:editorialNote "TODO: attach CWE identifiers to each vulnerability class (e.g. CWE-269 for privilege management, CWE-250 execution with unnecessary privileges, CWE-319 cleartext transmission for AbsentIngressTLS)." .


#################################################################
#    Classes
#################################################################

###  https://w3id.org/kcro#AbsentIngressTLS
kcro:AbsentIngressTLS rdf:type owl:Class ;
                      rdfs:subClassOf kcro:VulnerabilityByOmission ,
                [ rdf:type owl:Restriction ;
                  owl:onProperty gufo:inheresIn ;
                  owl:someValuesFrom kcro:Ingress
                ] ;
                      dcterms:source kcro:Rahman2024 ;
                      rdfs:label "Absent Ingress TLS"@en ;
                      kcro:corpusCount 608 ;
                      kcro:datasetKey "ingress.tls=missing" ;
                      kcro:groundingNote "Maps to Rahman 2024's 'Insecure HTTP' (transport without TLS), applied at the Ingress." .


###  https://w3id.org/kcro#AbsentResourceLimit
kcro:AbsentResourceLimit rdf:type owl:Class ;
                         rdfs:subClassOf kcro:VulnerabilityByOmission ,
                [ rdf:type owl:Restriction ;
                  owl:onProperty gufo:inheresIn ;
                  owl:someValuesFrom kcro:Container
                ] ;
                         dcterms:source kcro:Rahman2024 ;
                         rdfs:label "Absent Resource Limit"@en ;
                         kcro:corpusCount 14195 ;
                         kcro:datasetKey "container.resources.limits=missing" ;
                         kcro:groundingNote "Explicit in Rahman 2024 ('Absent Resource Limit'). Highest-prevalence omission in the corpus." .


###  https://w3id.org/kcro#AbsentRunAsNonRoot
kcro:AbsentRunAsNonRoot rdf:type owl:Class ;
                        rdfs:subClassOf kcro:VulnerabilityByOmission ,
                [ rdf:type owl:Restriction ;
                  owl:onProperty gufo:inheresIn ;
                  owl:someValuesFrom kcro:Pod
                ] ;
                        dcterms:source kcro:Rahman2024 ;
                        rdfs:label "Absent runAsNonRoot"@en ;
                        kcro:corpusCount 12720 ;
                        kcro:datasetKey "pod.securityContext.runAsNonRoot=missing" ;
                        kcro:groundingNote "Within Rahman 2024's 'Absent securityContext'. Resolvable to confirmed-root by joining with image USER metadata (future work)." .


###  https://w3id.org/kcro#AddedLinuxCapabilities
kcro:AddedLinuxCapabilities rdf:type owl:Class ;
                            rdfs:subClassOf kcro:VulnerabilityByCommission ,
                [ rdf:type owl:Restriction ;
                  owl:onProperty gufo:inheresIn ;
                  owl:someValuesFrom kcro:Container
                ] ;
                            dcterms:source kcro:Rahman2024 ;
                            rdfs:label "Added Linux Capabilities"@en ;
                            kcro:corpusCount 493 ;
                            kcro:datasetKey "container.capabilities.add=set" ;
                            kcro:groundingNote "Rahman 2024 ('Capability Misuse'); Rahman flags CAP_SYS_ADMIN / CAP_SYS_MODULE specifically — corpus check is broader (any added capability)." .


###  https://w3id.org/kcro#AutomountTokenEnabled
kcro:AutomountTokenEnabled rdf:type owl:Class ;
                           rdfs:subClassOf kcro:VulnerabilityByOmission ,
                [ rdf:type owl:Restriction ;
                  owl:onProperty gufo:inheresIn ;
                  owl:someValuesFrom kcro:Pod
                ] ;
                           dcterms:source kcro:CISBenchmark ;
                           rdfs:label "ServiceAccount Token Automount Not Disabled"@en ;
                           kcro:corpusCount 13365 ;
                           kcro:datasetKey "pod.automountServiceAccountToken=missing" ;
                           kcro:groundingNote "Insecure default (token mounted unless explicitly disabled). NOT in Rahman 2024. Grounded in CIS Kubernetes Benchmark v1.5.1 control 5.1.6 (Service Account Tokens only mounted where necessary); the CIS remediation for 5.1.5 likewise prescribes automountServiceAccountToken: false. Verified 2026-06-10 against KGSecConfig (Haque 2022): the paper mines component-level secured-configuration knowledge from official documentation and does not enumerate this manifest-level pattern, so it is not cited." .


###  https://w3id.org/kcro#ClusterAdminBinding
kcro:ClusterAdminBinding rdf:type owl:Class ;
                         rdfs:subClassOf kcro:VulnerabilityByCommission ,
                [ rdf:type owl:Restriction ;
                  owl:onProperty gufo:inheresIn ;
                  owl:someValuesFrom kcro:KubernetesRelation
                ] ;
                         dcterms:source kcro:Aliforenko2025 ,
                                        kcro:CISBenchmark ;
                         rdfs:comment "This vulnerability inheres in a binding relator (a KubernetesRelation), not in a plain object; see the worked-example individuals exampleAdminVuln and exampleBinding."@en ;
                         rdfs:label "cluster-admin Binding"@en ;
                         kcro:corpusCount 101 ;
                         kcro:datasetKey "binding.roleRef.name=cluster-admin" ;
                         kcro:groundingNote "Binding a subject to cluster-admin. Grounded in CIS Kubernetes Benchmark v1.5.1 control 5.1.1 (cluster-admin role only used where required); flagged as a privilege-escalation concern in Aliforenko 2025. Verified 2026-06-10 against KGSecConfig (Haque 2022): the paper mines component-level secured-configuration knowledge from official documentation and does not enumerate this manifest-level pattern, so it is not cited." .


###  https://w3id.org/kcro#ClusterIPExposure
kcro:ClusterIPExposure rdf:type owl:Class ;
                       rdfs:subClassOf kcro:ServiceExposureLevel ;
                       rdfs:label "ClusterIP (internal only)"@en ;
                       skos:note "Safe default — internal only. Recorded for completeness, not a misconfiguration." ;
                       kcro:corpusCount 12011 ;
                       kcro:datasetKey "service.type=ClusterIP" .


###  https://w3id.org/kcro#ClusterRole
kcro:ClusterRole rdf:type owl:Class ;
                 rdfs:subClassOf kcro:PermissionResource .


###  https://w3id.org/kcro#ClusterRoleBinding
kcro:ClusterRoleBinding rdf:type owl:Class ;
                        rdfs:subClassOf kcro:KubernetesRelation .


###  https://w3id.org/kcro#ConfigMap
kcro:ConfigMap rdf:type owl:Class ;
               rdfs:subClassOf kcro:DataResource .


###  https://w3id.org/kcro#Container
kcro:Container rdf:type owl:Class ;
               rdfs:subClassOf kcro:WorkloadResource .


###  https://w3id.org/kcro#ContainerImage
kcro:ContainerImage rdf:type owl:Class ;
                    rdfs:subClassOf kcro:WorkloadResource .


###  https://w3id.org/kcro#ContainerRunAsRoot
kcro:ContainerRunAsRoot rdf:type owl:Class ;
                        rdfs:subClassOf kcro:VulnerabilityByCommission ,
                [ rdf:type owl:Restriction ;
                  owl:onProperty gufo:inheresIn ;
                  owl:someValuesFrom kcro:Container
                ] ;
                        dcterms:source kcro:Rahman2024 ;
                        rdfs:label "Container Runs As Root"@en ;
                        kcro:corpusCount 297 ;
                        kcro:datasetKey "container.securityContext.runAsUser=0" ;
                        kcro:groundingNote "Within Rahman 2024's securityContext family; runAsUser=0 as an explicit value is a refinement of that category." .


###  https://w3id.org/kcro#CronJob
kcro:CronJob rdf:type owl:Class ;
             rdfs:subClassOf kcro:WorkloadResource .


###  https://w3id.org/kcro#DaemonSet
kcro:DaemonSet rdf:type owl:Class ;
               rdfs:subClassOf kcro:WorkloadResource .


###  https://w3id.org/kcro#DataResource
kcro:DataResource rdf:type owl:Class ;
                  rdfs:subClassOf kcro:KubernetesObject .


###  https://w3id.org/kcro#DefaultServiceAccount
kcro:DefaultServiceAccount rdf:type owl:Class ;
                           rdfs:subClassOf kcro:VulnerabilityByOmission ,
                [ rdf:type owl:Restriction ;
                  owl:onProperty gufo:inheresIn ;
                  owl:someValuesFrom kcro:Pod
                ] ;
                           dcterms:source kcro:CISBenchmark ;
                           rdfs:label "Default ServiceAccount Used"@en ;
                           kcro:corpusCount 8122 ;
                           kcro:datasetKey "pod.serviceAccount=default" ;
                           kcro:groundingNote "No dedicated ServiceAccount declared. NOT in Rahman 2024. Grounded in CIS Kubernetes Benchmark v1.5.1 control 5.1.5 (default service accounts not actively used). Verified 2026-06-10 against KGSecConfig (Haque 2022): the paper mines component-level secured-configuration knowledge from official documentation and does not enumerate this manifest-level pattern, so it is not cited." .


###  https://w3id.org/kcro#Deployment
kcro:Deployment rdf:type owl:Class ;
                rdfs:subClassOf kcro:WorkloadResource .


