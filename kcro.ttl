kcro:ServiceAccount rdf:type owl:Class ;
                    rdfs:subClassOf kcro:IdentityResource .


###  https://w3id.org/kcro#ServiceExposureLevel
kcro:ServiceExposureLevel rdf:type owl:Class ;
                          rdfs:subClassOf kcro:SecurityQuality ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty gufo:inheresIn ;
                                            owl:someValuesFrom kcro:Service
                                          ] .


###  https://w3id.org/kcro#ServiceRouting
kcro:ServiceRouting rdf:type owl:Class ;
                    rdfs:subClassOf kcro:KubernetesRelation .


###  https://w3id.org/kcro#StatefulSet
kcro:StatefulSet rdf:type owl:Class ;
                 rdfs:subClassOf kcro:WorkloadResource .


###  https://w3id.org/kcro#ThreatAgent
kcro:ThreatAgent rdf:type owl:Class ;
                 rdfs:subClassOf gufo:Object .


###  https://w3id.org/kcro#ThreatCapability
kcro:ThreatCapability rdf:type owl:Class ;
                      rdfs:subClassOf kcro:SecurityDisposition .


###  https://w3id.org/kcro#ThreatEvent
kcro:ThreatEvent rdf:type owl:Class ;
                 rdfs:subClassOf gufo:Event .


###  https://w3id.org/kcro#ThreatIntelDescriptor
kcro:ThreatIntelDescriptor rdf:type owl:Class ;
                           rdfs:subClassOf kcro:InformationObject .


###  https://w3id.org/kcro#VolumeMount
kcro:VolumeMount rdf:type owl:Class ;
                 rdfs:subClassOf kcro:KubernetesRelation .


###  https://w3id.org/kcro#Vulnerability
kcro:Vulnerability rdf:type owl:Class ;
                   rdfs:subClassOf kcro:SecurityDisposition .


###  https://w3id.org/kcro#VulnerabilityByCommission
kcro:VulnerabilityByCommission rdf:type owl:Class ;
                               rdfs:subClassOf kcro:Vulnerability ;
                               owl:disjointWith kcro:VulnerabilityByOmission ;
                               rdfs:comment "Grounded by an explicitly-set dangerous value (e.g. privileged: true). Decidable from the manifest alone; a confirmed, deliberate risk."@en ;
                               rdfs:label "Vulnerability by Commission"@en .


###  https://w3id.org/kcro#VulnerabilityByOmission
kcro:VulnerabilityByOmission rdf:type owl:Class ;
                             rdfs:subClassOf kcro:Vulnerability ;
                             rdfs:comment "Grounded by the ABSENCE of a protective setting, leaving the insecure-by-default state in place (e.g. resources.limits missing). An upper bound on potential exposure rather than a confirmed exploit."@en ;
                             rdfs:label "Vulnerability by Omission"@en .


###  https://w3id.org/kcro#WildcardAPIGroups
kcro:WildcardAPIGroups rdf:type owl:Class ;
                       rdfs:subClassOf kcro:VulnerabilityByCommission ,
                [ rdf:type owl:Restriction ;
                  owl:onProperty gufo:inheresIn ;
                  owl:someValuesFrom kcro:PermissionResource
                ] ;
                       dcterms:source kcro:CISBenchmark ;
                       rdfs:label "Wildcard RBAC API Groups"@en ;
                       kcro:corpusCount 290 ;
                       kcro:datasetKey "rbac.rule.apiGroups=wildcard" ;
                       kcro:groundingNote "As above (RBAC); grounded in CIS Kubernetes Benchmark v1.5.1 control 5.1.3 (minimize wildcard use in Roles and ClusterRoles)." .


###  https://w3id.org/kcro#WildcardResources
kcro:WildcardResources rdf:type owl:Class ;
                       rdfs:subClassOf kcro:VulnerabilityByCommission ,
                [ rdf:type owl:Restriction ;
                  owl:onProperty gufo:inheresIn ;
                  owl:someValuesFrom kcro:PermissionResource
                ] ;
                       dcterms:source kcro:CISBenchmark ;
                       rdfs:label "Wildcard RBAC Resources"@en ;
                       kcro:corpusCount 566 ;
                       kcro:datasetKey "rbac.rule.resources=wildcard" ;
                       kcro:groundingNote "As above (RBAC); grounded in CIS Kubernetes Benchmark v1.5.1 control 5.1.3 (minimize wildcard use in Roles and ClusterRoles)." .


###  https://w3id.org/kcro#WildcardVerbs
kcro:WildcardVerbs rdf:type owl:Class ;
                   rdfs:subClassOf kcro:VulnerabilityByCommission ,
                [ rdf:type owl:Restriction ;
                  owl:onProperty gufo:inheresIn ;
                  owl:someValuesFrom kcro:PermissionResource
                ] ;
                   dcterms:source kcro:CISBenchmark ;
                   rdfs:label "Wildcard RBAC Verbs"@en ;
                   kcro:corpusCount 1684 ;
                   kcro:datasetKey "rbac.rule.verbs=wildcard" ;
                   kcro:groundingNote "RBAC over-permission. NOT in Rahman 2024 (which omits RBAC). Grounded in CIS Kubernetes Benchmark v1.5.1 control 5.1.3 (minimize wildcard use in Roles and ClusterRoles) — a least-privilege violation. Verified 2026-06-10 against KGSecConfig (Haque 2022): the paper mines component-level secured-configuration knowledge from official documentation and does not enumerate this manifest-level pattern, so it is not cited." .


###  https://w3id.org/kcro#WorkloadManagement
kcro:WorkloadManagement rdf:type owl:Class ;
                        rdfs:subClassOf kcro:KubernetesRelation .


###  https://w3id.org/kcro#WorkloadResource
kcro:WorkloadResource rdf:type owl:Class ;
                      rdfs:subClassOf kcro:KubernetesObject .


